               <resource_enum id="_0x3010f" name="PIR funktion" typedef="_0x2e947" inivalue="_0x2ea48" backup="yes" icon="_0x22" note="Her er det muligt, at vælge hvilken funktion PIR&apos;en skal have dag/aften.&#xD;&#xA;Vælg mellem:&#xD;&#xA;&#xD;&#xA;&quot;Tænder lys&quot;&#xD;&#xA;&quot;Kun efterløb&quot;&#xD;&#xA;"/>
               <resource_enum id="_0x3020f" name="PIR funktion nat" typedef="_0x2ec47" inivalue="_0x2ed48" backup="yes" icon="_0x22" note="Her er det muligt, at vælge hvilken funktion PIR&apos;en skal have om natten.&#xD;&#xA;Natdrift indgangen skal benyttes for at opnå funktion.&#xD;&#xA;&#xD;&#xA;Vælg mellem:&#xD;&#xA;&#xD;&#xA;&quot;Tænder lys&quot;&#xD;&#xA;&quot;Kun efterløb&quot;&#xD;&#xA;"/>
               <resource_enum id="_0x3030f" name="Manuel tænding" typedef="_0x2e647" inivalue="_0x2e748" icon="_0x22" note="Her er det muligt, at vælge funktion på manuel tænding.&#xD;&#xA;&#xD;&#xA;Vælg mellem:&#xD;&#xA;&#xD;&#xA;Ved &quot;Starter efterløb&quot; vil lys slukke på efterløb efter sidste påvirking af PIR eller tryk.&#xD;&#xA;Ved &quot;Spærrer efterløb&quot; vil lys ikke slukke ved skumringsfrafald når manuel betjening er aktiv."/>

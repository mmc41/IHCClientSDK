         <functionblock id="_0x2e528" name="1.4.02.a. PIR styring " master_schneider_electric="yes" master_type="1.4.02" master_version="a" master_name="PIR styring " master_programmer="Schneider Electric&#xD;&#xA;Copyrights © 2016" master_date_year="2017" master_date_month="9" master_date_day="14" locked="yes" icon="_0xe" note="1.4.02.a. PIR styring &#xD;&#xA;&#xD;&#xA;Anvendelse:&#xD;&#xA;Til simpel styring af IHC Wireless produkter og relæer ifm. PIR og manuel betjening.&#xD;&#xA;&#xD;&#xA;For at se den fulde beskrivelse marker denne linje og tryk &quot;F1&quot;.&#xD;&#xA;Bemærk: Dette virker kun hvis blokken er rød-markeret.">
            <inputs id="_0x2ef23" name="Input" icon="_0x4" note="Variablene i denne gruppering er input til funktionsblokken">
               <resource_input id="_0x2f011" name="PIR" icon="_0x36" note="Forbindes til tilstedeværelses indikering fra PIR sensor.&#xD;&#xA;Virkemåde defineres under indstillinger:&#xD;&#xA; &quot;# PIR funktion&quot;&#xD;&#xA; &quot;# PIR funktion nat&quot;&#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0x2f111" name="Skumring" icon="_0x36" note="Forbindes fra skumringssensor eller luxsensor ifm. funktionsblok 1.1.12&#xD;&#xA;Alternativt via ur funktionsblok.&#xD;&#xA;(Udfyldes af installatøren)&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" inivalue="on"/>
               <resource_input id="_0x2f211" name="Tilbagemelding" icon="_0x36" note="Opret link mellem produktets &quot;Udgang&quot; og &quot;Tilbagemelding&quot;.&#xD;&#xA;Ved tilbagemelding begrænses genkald af IHC Wireless produkter ifm. PIR aktivitet."/>
               <resource_input id="_0x2f311" name="Natdrift" icon="_0x36" note="Anvendes som begrænsning for PIR funktion om natten.&#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0x2f411" name="Kip" icon="_0x36" note="Kipper udgang og scenarier&#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0x2f511" name="Tænd" icon="_0x36" note="Tænder udgang og scenarie &#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0x2f611" name="Sluk" icon="_0x36" note="Slukker udgang og scenarie.&#xD;&#xA;(Udfyldes af installatøren)&#xD;&#xA;"/>
               <resource_input id="_0x2f711" name="Spærring" icon="_0x36" note="Når denne indgang er on, vil al automatik være spærret. Dette giver mulighed for total spærring i både tændt og slukket tilstand.&#xD;&#xA;(Udfyldes af installatøren)&#xD;&#xA;"/>
            </inputs>
            <outputs id="_0x2f824" name="Output" icon="_0x14" note="Variablene i denne gruppering er output fra funktionsblokken">
               <resource_output id="_0x2f912" name="Udgang" icon="_0x39" note="Forbindes til relæ hvis scenariefunktion ikke benyttes.&#xD;&#xA;"/>
               <resource_output id="_0x2fa12" name="ON puls" icon="_0x39" note="Giver kort puls ved tænding.&#xD;&#xA;Anvendes til styring af andre blokke."/>
               <resource_output id="_0x2fb12" name="OFF puls" icon="_0x39" note="Giver kort puls ved slukning.&#xD;&#xA;Anvendes til styring af andre blokke."/>
               <resource_output id="_0x2fc12" name="Manuelt betjent" icon="_0x39" note="Visning af overstyring af PIR. &#xD;&#xA;Kan benyttes til diode eller Viewer.&#xD;&#xA;Ifm. manuel sluk vil udgang blinke (default 15 sek.) som kvittéring for spærring af PIR."/>
               <resource_scene id="_0x2fd4a" name="Scenarie tænd" note="Forbindes til relæ og/eller IHC Wireless lysdæmper."/>
               <resource_scene id="_0x2fe4a" name="Scenarie sluk" note="Forbindes til relæ og/eller IHC Wireless lysdæmper."/>
            </outputs>

      <group id="_0x2732" name="Bryggers" icon="_0x15">
         <functionblock id="_0x4b928" name="4.1.04. Driftstimetæller" master_schneider_electric="yes" master_type="4.1.04" master_name="Driftstimetæller" master_programmer="Schneider Electric&#xD;&#xA;Copyrights © 2009" master_date_year="2017" master_date_month="4" master_date_day="29" locked="yes" icon="_0xe" note="4.1.04. Driftstimetæller&#xD;&#xA;&#xD;&#xA;Anvendes:&#xD;&#xA;Til at tælle time forbrug på f.eks lysrør, eller steder hvor forebyggende vedligehold ønskes. &#xD;&#xA;Dette vises i Timer.&#xD;&#xA;&#xD;&#xA;For at se den fulde beskrivelse marker denne linje og tryk &quot;F1&quot;.&#xD;&#xA;Bemærk: Dette virker kun hvis &quot;Blokken&quot; er rød-markeret.">
            <inputs id="_0x4ba23" name="Input" icon="_0x4">
               <resource_input id="_0x4bb11" name="Indgang" icon="_0x36" note="Når denne indgang er &quot;ON&quot; tæller tiden op.&#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0x4bc11" name="Reset" icon="_0x36" note="Aktiveres ved et langt tryk.&#xD;&#xA;Skal holdes inde i  &gt;1sek før &quot;Reset&quot; udføres.&#xD;&#xA;(Udfyldes af installatøren)"/>
            </inputs>
            <outputs id="_0x4bd24" name="Output" icon="_0x14">
               <resource_output id="_0x4be12" name="Indikation" backup="yes" icon="_0x39" note="Denne udgang kan bruges til en Diode, der indikerer at &quot;Set-punktet&quot; er opnået.&#xD;&#xA;Denne kan ligeledes anvendes til at sende en mail til værkfører eller elektriker om f.eks. &quot;Det er tid til at skifte lysrør&quot;"/>
               <resource_counter id="_0x4bf0c" name="Timer" backup="yes" note="Kan anvendes i Viewer."/>
               <resource_counter id="_0x4c00c" name="Minut" backup="yes" note="Kan anvendes i Viewer."/>
               <resource_counter id="_0x4c10c" name="Sekund" backup="yes" note="Kan anvendes i Viewer."/>
            </outputs>

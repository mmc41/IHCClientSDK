         <functionblock id="_0xf528" name="1.2.04.e. Trådløs / Bus lysdæmper" master_schneider_electric="yes" master_type="1.2.04" master_version="e" master_name="Trådløs / Bus lysdæmper" master_programmer="Schneider Electric&#xD;&#xA;Copyrights © 2016" master_date_year="2017" master_date_month="9" master_date_day="11" locked="yes" icon="_0xe" note="1.2.04.e. Trådløs / Bus lysdæmper&#xD;&#xA;&#xD;&#xA;Anvendelse:&#xD;&#xA;Til styring af IHC Wireless og IHC Bus lysdæmpere.&#xD;&#xA;Kan anvendes som 1- og/eller 2-tast betjent regulering samt fremkald og gem høj/lav.&#xD;&#xA;&#xD;&#xA;For at se den fulde beskrivelse; markér overskrift på funktionsblok og tryk F1.&#xD;&#xA;Bemærk: Dette virker kun hvis blokken er rød-markeret.&#xD;&#xA;">
            <inputs id="_0x10423" name="Input" icon="_0x4" note="Variablene i denne gruppering er input til funktionsblokken">
               <resource_input id="_0x10511" name="Touch " icon="_0x36" note="Kort tryk tænd/sluk - langt tryk regulerer lys niveau op/ned.&#xD;&#xA;(Udfyldes af installatøren)&#xD;&#xA;"/>
               <resource_input id="_0x10611" name="Tænd/regulér op" icon="_0x36" note="Kort tryk tænd - langt tryk regulerer lysniveau op.&#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0x10711" name="Sluk/regulér ned  " icon="_0x36" note="Kort tryk sluk - langt tryk regulerer lysniveau ned.&#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0x10811" name="Høj" icon="_0x36" note="Fremkalder højt lysniveau.&#xD;&#xA;Tryk over 3 sek. vil gemme det aktuelle lysniveau som høj.&#xD;&#xA;Som kvittering slukker lys og gentænder når tryk slippes.&#xD;&#xA;Niveau gemmes kun, hvis lysdæmper er tændt.&#xD;&#xA;(Udfyldes af installatøren)&#xD;&#xA;"/>
               <resource_input id="_0x10911" name="Lav " icon="_0x36" note="Fremkalder lavt lysniveau.&#xD;&#xA;Tryk over 3 sek. vil gemme det aktuelle lysniveau som lav.&#xD;&#xA;Som kvittering slukker lys og gentænder når tryk slippes.&#xD;&#xA;Niveau gemmes kun, hvis lysdæmper er tændt.&#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_light_level id="_0x10a13" name="Lys niveau " note="Opret link mellem produktets &quot;Lys niveau&quot; og denne indgang"/>
               <resource_input id="_0x10b11" name="Natdrift" icon="_0x36" note="Ved aktivitet (betingelse opfyldt) vil et kort regulerings tryk tænde lyset på &quot;Lavt niveau&quot;. PIR vil enten være helt eller delvist begrænset.&#xD;&#xA;Sammensættes med urfunktion eller dag og nat funktion.&#xD;&#xA;(Udfyldes af installatøren)"/>
            </inputs>
            <outputs id="_0x10c24" name="Output" icon="_0x14" note="Variablene i denne gruppering er output fra funktionsblokken">
               <resource_scene id="_0x10d4a" name="Højt niveau" note="Forbindes til lysdæmperen med det ønskede lysniveau og rampetid.&#xD;&#xA;Default 100%, rampetid 1 sek.&#xD;&#xA;Dette scenarie benyttes til at fremkalde niveauet, regulere samt sluke lysdæmper." hide_dialog="yes"/>
               <resource_scene id="_0x10e4a" name="Lavt niveau" note="Forbindes til lysdæmperen med det ønskede lysniveau og rampetid.&#xD;&#xA;"/>
               <resource_enum id="_0x10f0f" name="Lysdæmper status" typedef="_0xfa47" inivalue="_0xfc48" backup="yes" icon="_0x22" note="Status indikering til Viewer."/>
               <resource_output id="_0x11012" name="Lysdæmper tændt" backup="yes" icon="_0x39" note="Status indikering i diode eller Viewer."/>
            </outputs>
            <settings id="_0x11125" name="Indstillinger" icon="_0xd" note="Variablene i denne gruppering er indstillinger til funktionsblokken">
               <resource_enum id="_0x1120f" name="Kort reguleringstryk tænder" typedef="_0xf647" inivalue="_0xf748" backup="yes" icon="_0x22" note="Her er det muligt, at vælge funktionalitet på reguleringstryk dag/aften.&#xD;&#xA;Vælg mellem:&#xD;&#xA;&#xD;&#xA;Højt niveau&#xD;&#xA;Lavt niveau&#xD;&#xA;Sidste niveau" note-2="Dette valg er kun aktivt dag/aften. Om natten (natdrift anvendt) vil et kort reguleringstryk tænde lys på lavt niveau.&#xD;&#xA;Ved frafald af &quot;Natdrift&quot; vil &quot;Højt niveau&quot; fremkaldes første gang der trykkes kort reguleringstryk selvom &quot;Sidste niveau&quot; er valgt. Dette er valgt fordi ny dag er kommet og gl. niveau ikke er relevant mere. "/>
            </settings>
            <internalsettings id="_0x11329" name="Interne variable" icon="_0x13" note="Variablene i denne gruppe er private variable til funktionsblokken">
               <resource_timer id="_0x11410" name="Gem nyt scenarie efter " icon="_0x43" hour="0" minute="0" second="3" millisecond="0"/>
               <resource_timer id="_0x11510" name="Kvittér med blink af scenarie" icon="_0x43" hour="0" minute="0" second="1" millisecond="0"/>

               <resource_counter id="_0x4c30c" name="Set-Punkt" backup="yes" note="Default 10.000&#xD;&#xA;Hvis &quot;Timer&quot; bliver =&gt; &quot;Set-punkt&quot; vil &quot;Indikation&quot; blive &quot;ON&quot; &#xD;&#xA;Rettes &quot;Set-Punkt&quot; til en højre værdi end &quot;Timer&quot; vil &quot;Indikation&quot; blive &quot;OFF&quot; indtil &quot;Set-punkt&quot; igen bliver nået." inivalue="10000"/>

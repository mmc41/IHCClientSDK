      <group id="_0x2232" name="Entré" icon="_0x15">
         <product_dataline id="_0xc753" product_identifier="_0x2201" name="Stikkontakt" locked="yes" icon="_0x88" note="note4" position="ved hoveddør og udestuedør - 2 stk, fælles tilslutning" cabletype="5x1,5mm2 NOIKJ" cablenumber="3" documentation_tag="test3" power_group="gruppe3">
            <dataline_output id="_0xc85b" name="Udgang" backup="yes" address_dataline="_0x9">
               <link_to_resource id="_0x2142c" name="Følg Link" icon="_0x4a" link="_0x2132d"/>
            </dataline_output>
            <scenes id="_0xc949" name="Scenarier" scene_resource="_0xc85b"/>
         </product_dataline>
         <functionblock id="_0xca28" name="1.4.02.a. PIR styring " master_schneider_electric="yes" master_type="1.4.02" master_version="a" master_name="PIR styring " master_programmer="Schneider Electric&#xD;&#xA;Copyrights © 2016" master_date_year="2017" master_date_month="9" master_date_day="14" locked="yes" icon="_0xe" note="1.4.02.a. PIR styring &#xD;&#xA;&#xD;&#xA;Anvendelse:&#xD;&#xA;Til simpel styring af IHC Wireless produkter og relæer ifm. PIR og manuel betjening.&#xD;&#xA;&#xD;&#xA;For at se den fulde beskrivelse marker denne linje og tryk &quot;F1&quot;.&#xD;&#xA;Bemærk: Dette virker kun hvis blokken er rød-markeret.">
            <inputs id="_0xd423" name="Input" icon="_0x4" note="Variablene i denne gruppering er input til funktionsblokken">
               <resource_input id="_0xd511" name="PIR" icon="_0x36" note="Forbindes til tilstedeværelses indikering fra PIR sensor.&#xD;&#xA;Virkemåde defineres under indstillinger:&#xD;&#xA; &quot;# PIR funktion&quot;&#xD;&#xA; &quot;# PIR funktion nat&quot;&#xD;&#xA;(Udfyldes af installatøren)">
                  <link_to_resource id="_0x2122c" name="Følg Link" icon="_0x4a" link="_0x2112d"/>
               </resource_input>
               <resource_input id="_0xd611" name="Skumring" icon="_0x36" note="Forbindes fra skumringssensor eller luxsensor ifm. funktionsblok 1.1.12&#xD;&#xA;Alternativt via ur funktionsblok.&#xD;&#xA;(Udfyldes af installatøren)&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" inivalue="on"/>
               <resource_input id="_0xd711" name="Tilbagemelding" icon="_0x36" note="Opret link mellem produktets &quot;Udgang&quot; og &quot;Tilbagemelding&quot;.&#xD;&#xA;Ved tilbagemelding begrænses genkald af IHC Wireless produkter ifm. PIR aktivitet."/>
               <resource_input id="_0xd811" name="Natdrift" icon="_0x36" note="Anvendes som begrænsning for PIR funktion om natten.&#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0xd911" name="Kip" icon="_0x36" note="Kipper udgang og scenarier&#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0xda11" name="Tænd" icon="_0x36" note="Tænder udgang og scenarie &#xD;&#xA;(Udfyldes af installatøren)"/>
               <resource_input id="_0xdb11" name="Sluk" icon="_0x36" note="Slukker udgang og scenarie.&#xD;&#xA;(Udfyldes af installatøren)&#xD;&#xA;"/>
               <resource_input id="_0xdc11" name="Spærring" icon="_0x36" note="Når denne indgang er on, vil al automatik være spærret. Dette giver mulighed for total spærring i både tændt og slukket tilstand.&#xD;&#xA;(Udfyldes af installatøren)&#xD;&#xA;"/>
            </inputs>
            <outputs id="_0xdd24" name="Output" icon="_0x14" note="Variablene i denne gruppering er output fra funktionsblokken">
               <resource_output id="_0xde12" name="Udgang" icon="_0x39" note="Forbindes til relæ hvis scenariefunktion ikke benyttes.&#xD;&#xA;">
                  <link_from_resource id="_0x2132d" name="Følg Link" icon="_0x47" link="_0x2142c"/>
               </resource_output>
               <resource_output id="_0xdf12" name="ON puls" icon="_0x39" note="Giver kort puls ved tænding.&#xD;&#xA;Anvendes til styring af andre blokke."/>
               <resource_output id="_0xe012" name="OFF puls" icon="_0x39" note="Giver kort puls ved slukning.&#xD;&#xA;Anvendes til styring af andre blokke."/>
               <resource_output id="_0xe112" name="Manuelt betjent" icon="_0x39" note="Visning af overstyring af PIR. &#xD;&#xA;Kan benyttes til diode eller Viewer.&#xD;&#xA;Ifm. manuel sluk vil udgang blinke (default 15 sek.) som kvittéring for spærring af PIR."/>
               <resource_scene id="_0xe24a" name="Scenarie tænd" note="Forbindes til relæ og/eller IHC Wireless lysdæmper."/>
               <resource_scene id="_0xe34a" name="Scenarie sluk" note="Forbindes til relæ og/eller IHC Wireless lysdæmper."/>
            </outputs>
            <settings id="_0xe425" name="Indstillinger" icon="_0xd" note="Variablene i denne gruppering er indstillinger til funktionsblokken">
               <resource_timer id="_0xe510" name="Efterløb" backup="yes" icon="_0x43" note="Her indstilles efterløbstiden.&#xD;&#xA;" hour="0" minute="3" second="0" millisecond="0"/>
               <resource_enum id="_0xe60f" name="PIR funktion" typedef="_0xce47" inivalue="_0xcf48" backup="yes" icon="_0x22" note="Her er det muligt, at vælge hvilken funktion PIR&apos;en skal have dag/aften.&#xD;&#xA;Vælg mellem:&#xD;&#xA;&#xD;&#xA;&quot;Tænder lys&quot;&#xD;&#xA;&quot;Kun efterløb&quot;&#xD;&#xA;"/>
               <resource_enum id="_0xe70f" name="PIR funktion nat" typedef="_0xd147" inivalue="_0xd248" backup="yes" icon="_0x22" note="Her er det muligt, at vælge hvilken funktion PIR&apos;en skal have om natten.&#xD;&#xA;Natdrift indgangen skal benyttes for at opnå funktion.&#xD;&#xA;&#xD;&#xA;Vælg mellem:&#xD;&#xA;&#xD;&#xA;&quot;Tænder lys&quot;&#xD;&#xA;&quot;Kun efterløb&quot;&#xD;&#xA;"/>
               <resource_enum id="_0xe80f" name="Manuel tænding" typedef="_0xcb47" inivalue="_0xcc48" icon="_0x22" note="Her er det muligt, at vælge funktion på manuel tænding.&#xD;&#xA;&#xD;&#xA;Vælg mellem:&#xD;&#xA;&#xD;&#xA;Ved &quot;Starter efterløb&quot; vil lys slukke på efterløb efter sidste påvirking af PIR eller tryk.&#xD;&#xA;Ved &quot;Spærrer efterløb&quot; vil lys ikke slukke ved skumringsfrafald når manuel betjening er aktiv."/>
            </settings>

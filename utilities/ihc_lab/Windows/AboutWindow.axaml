<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
        x:Class="IhcLab.AboutWindow"
        Title="About IHC Lab"
        Width="400" Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="false">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Project Name -->
        <TextBlock Grid.Row="0"
                   Text="IHC Lab"
                   FontSize="{StaticResource TitleFontSize}"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <!-- GitHub Link -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <TextBlock Text="GitHub: " VerticalAlignment="Center"/>
            <TextBlock Name="RepoLink"
                       Foreground="{StaticResource LinkBrush}"
                       TextDecorations="Underline"
                       Cursor="Hand"
                       PointerPressed="OnRepoLinkClick"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Author -->
        <TextBlock Name="RepoAuthors" Grid.Row="4"
                   FontSize="{StaticResource SubheadingFontSize}"
                   HorizontalAlignment="Center"/>

        <!-- Description -->
        <TextBlock Name="AppDescription" Grid.Row="6"
                   FontSize="{StaticResource BodyFontSize}"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource SecondaryTextBrush}"/>

        <!-- Version Information -->
        <StackPanel Grid.Row="7"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">
            <TextBlock Name="AppVersionText"
                       FontSize="{StaticResource CaptionFontSize}"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TertiaryTextBrush}"/>
            <TextBlock Name="SdkVersionText"
                       FontSize="{StaticResource CaptionFontSize}"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TertiaryTextBrush}"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Close Button -->
        <Button Grid.Row="8"
                Content="Close"
                Width="{StaticResource DialogButtonWidth}"
                HorizontalAlignment="Center"
                IsCancel="True"
                Click="OnCloseClick"/>
    </Grid>
</Window>
